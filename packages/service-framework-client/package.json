{
  "name": "@realitycollective/service-framework-client",
  "version": "1.0.0-preview.2",
  "description": "Base React and three.js client composition package for the Reality Collective TypeScript Service Framework.",
  "author": "Reality Collective",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "Examples"
  ],
  "keywords": [
    "service-framework",
    "react",
    "three",
    "threejs",
    "client",
    "realitycollective",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/realitycollective/com.realitycollective.service-framework.ts.git"
  },
  "homepage": "https://github.com/realitycollective/com.realitycollective.service-framework.ts#readme",
  "bugs": {
    "url": "https://github.com/realitycollective/com.realitycollective.service-framework.ts/issues"
  },
  "dependencies": {
    "@realitycollective/service-framework": "file:../service-framework",
    "@realitycollective/service-framework-react": "file:../service-framework-react",
    "@realitycollective/service-framework-three": "file:../service-framework-three"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
